---
/*
====================================================
ReflectionCard

Responsabilidad
Presentar una reflexión reciente como preview editorial.

Qué hace
Muestra imagen, fecha, lectura, título, frase, métricas opcionales, acceso al contenido y compartir siempre visible.

Qué no hace
No consulta Supabase ni administra likes o comentarios.

Dependencias
ShareActions, configuración pública, tipo Reflection y utilidades de presentación.

Decisión de interacción
Compartir vive junto a “Leer reflexión” y nunca depende del hover. El popover se eleva fuera de la tarjeta para que
el recorte visual de la imagen no limite la navegación con ratón, teclado o dispositivo táctil.

Cómo extenderlo
`entireCardClickable` amplía el enlace del título únicamente cuando una superficie de descubrimiento lo necesita.
La opción usa un enlace superpuesto y eleva las acciones independientes por encima. Así evita enlaces anidados y
conserva sin cambios la interacción de Home y relacionadas.

Autor: Daniel Montesinos
====================================================
*/

import ShareActions from '~/components/social/ShareActions.astro';
import { siteConfig } from '~/config/site';
import type { Reflection } from '~/features/reflections/types';
import { formatReflectionDate } from '~/utils/reflections';
import { createReflectionShareUrl } from '~/utils/share';

export interface Props {
  reflection: Reflection;
  likeCount?: number;
  commentCount?: number;
  entireCardClickable?: boolean;
  entrySource?: 'home_previous' | 'discover' | 'related';
}

const { reflection, likeCount, commentCount, entireCardClickable = false, entrySource } = Astro.props;
const href = `/reflexiones/${reflection.slug}`;
const shareUrl = createReflectionShareUrl({
  slug: reflection.slug,
  requestOrigin: Astro.url.origin,
  productionOrigin: siteConfig.brand.siteUrl,
  isProduction: import.meta.env.PROD,
});
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-[1.75rem] border border-stone-200 bg-white transition duration-500 hover:-translate-y-1.5 hover:border-stone-300 hover:shadow-[0_28px_70px_-40px_rgba(28,25,23,0.5)] dark:border-stone-800 dark:bg-stone-900 dark:hover:border-stone-700"
>
  {
    entireCardClickable ? (
      <div class="block overflow-hidden bg-stone-100 dark:bg-stone-800">
        <img
          src={reflection.image_url}
          alt=""
          width="800"
          height="500"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.035]"
        />
      </div>
    ) : (
      <a
        href={href}
        data-reflection-source={entrySource}
        tabindex="-1"
        aria-hidden="true"
        class="block overflow-hidden bg-stone-100 dark:bg-stone-800"
      >
        <img
          src={reflection.image_url}
          alt=""
          width="800"
          height="500"
          loading="lazy"
          decoding="async"
          class="aspect-[16/10] h-full w-full object-cover transition duration-700 ease-out group-hover:scale-[1.035]"
        />
      </a>
    )
  }
  {
    entireCardClickable && (
      <a
        href={href}
        data-reflection-source={entrySource}
        class="absolute inset-0 z-[1] rounded-[1.75rem] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-stone-950"
        aria-label={`Leer reflexión: ${reflection.title}`}
      >
        <span class="sr-only">Leer reflexión: {reflection.title}</span>
      </a>
    )
  }
  <div class:list={['flex flex-1 flex-col p-6 sm:p-7', entireCardClickable && 'pointer-events-none']}>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-medium text-stone-500 dark:text-stone-400">
      <time datetime={reflection.published_at}>{formatReflectionDate(reflection.published_at)}</time><span
        aria-hidden="true">·</span
      ><span>{reflection.reading_minutes || 3} min de lectura</span>
    </div>
    <h3
      class="mt-4 text-balance text-2xl font-semibold leading-tight tracking-[-0.025em] text-stone-950 dark:text-stone-50"
    >
      {
        entireCardClickable ? (
          reflection.title
        ) : (
          <a
            href={href}
            data-reflection-source={entrySource}
            class="rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-stone-950"
          >
            {reflection.title}
          </a>
        )
      }
    </h3>
    <blockquote
      class="mt-4 border-l-2 border-amber-300 pl-4 text-sm italic leading-6 text-stone-600 dark:border-amber-700 dark:text-stone-300"
    >
      “{reflection.quote}”
    </blockquote>
    <div class="relative z-10 mt-auto flex flex-wrap items-end gap-x-4 gap-y-3 pt-6">
      {
        (likeCount !== undefined || commentCount !== undefined) && (
          <p class="flex flex-1 flex-wrap gap-x-4 gap-y-1 pb-2 text-xs text-stone-500 dark:text-stone-400">
            {likeCount !== undefined && <span>♥ {likeCount} conexiones</span>}
            {commentCount !== undefined && <span>◌ {commentCount} comentarios</span>}
          </p>
        )
      }
      <div class="pointer-events-auto ml-auto flex items-center gap-2">
        <a
          href={href}
          data-reflection-source={entrySource}
          data-analytics-cta="leer_reflexion"
          class="inline-flex min-h-11 w-fit items-center border-b border-stone-300 py-2 text-sm font-semibold text-stone-900 transition duration-300 hover:border-stone-900 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-stone-900 dark:border-stone-700 dark:text-stone-100 dark:hover:border-stone-100"
        >
          Leer reflexión<span aria-hidden="true" class="ml-2 transition duration-300 group-hover:translate-x-1">→</span>
        </a>
        <ShareActions
          shareKey={`card-${reflection.id}`}
          title={reflection.title}
          quote={reflection.quote}
          author={siteConfig.brand.name}
          url={shareUrl}
        />
      </div>
    </div>
  </div>
</article>
