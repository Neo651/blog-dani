---
/*
====================================================
CommentsSection

Responsabilidad
Presentar la conversación asociada a una reflexión y conectar la UI con los servicios existentes.

Qué hace
Muestra el acceso, el editor y los comentarios aprobados con estados comprensibles y cercanos.

Datos que recibe
El id de la reflexión, la ruta segura de retorno OAuth y un modo visual opcional para integrarse al flujo de lectura.

Decisión de diseño
En una reflexión, el editor permanece visible antes del login para explicar con la propia interfaz dónde continuará
la conversación. Google aparece después como mecanismo de publicación, no como protagonista de la experiencia.
No se guarda un borrador previo al login: el campo es de solo lectura para evitar prometer persistencia durante OAuth.

Qué no hace
No define permisos, políticas RLS ni reglas de moderación; esas responsabilidades permanecen en sus servicios.

Dependencias
Servicios existentes de autenticación y comentarios.

Cómo se extiende
Las futuras mejoras de moderación deben vivir en servicios y RLS. El modo visual solo puede ajustar composición,
nunca permisos ni reglas de negocio.

Autor: Daniel Montesinos
====================================================
*/

export interface Props {
  reflectionId: number;
  reflectionSlug?: string;
  returnTo: string;
  mode?: 'default' | 'reading';
}

const { reflectionId, reflectionSlug = '', returnTo, mode = 'default' } = Astro.props;
const isReadingMode = mode === 'reading';
const textareaId = `comment-${reflectionId}`;
const guidanceId = `comment-guidance-${reflectionId}`;
---

<section
  id={isReadingMode ? 'conversacion' : undefined}
  data-comments-root
  data-reflection-id={reflectionId}
  data-reflection-slug={reflectionSlug}
  data-return-to={returnTo}
  data-mode={mode}
  class:list={[
    'mx-auto px-1',
    isReadingMode
      ? 'mt-4 max-w-[42rem] scroll-mt-24 pt-4 sm:mt-5 sm:px-0 sm:pt-5'
      : 'mt-14 max-w-3xl border-t border-stone-200 pt-10 dark:border-white/[0.07] sm:px-6',
  ]}
>
  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500 dark:text-stone-400">
    La conversación continúa
  </p>
  <h2 class="mt-3 text-2xl font-semibold tracking-tight text-stone-950 dark:text-stone-50 sm:text-3xl">
    ¿Qué idea se quedó contigo?
  </h2>
  <p class="mt-3 text-stone-500 dark:text-stone-400">
    {
      isReadingMode
        ? 'Comparte una reflexión o una pregunta.'
        : 'No hace falta tener una respuesta perfecta. Comparte una pregunta, una experiencia o una perspectiva distinta.'
    }
  </p>

  {!isReadingMode && <div data-comments-auth class="mt-6" />}
  <form data-comment-form class:list={[isReadingMode ? 'mt-5' : 'mt-6 hidden']}>
    <label
      for={textareaId}
      class:list={[isReadingMode ? 'mb-2 block text-sm font-medium text-stone-700 dark:text-stone-300' : 'sr-only']}
    >
      Tu reflexión
    </label>
    <textarea
      id={textareaId}
      data-comment-content
      required
      maxlength="1000"
      rows="4"
      readonly={isReadingMode}
      aria-disabled={isReadingMode ? 'true' : undefined}
      aria-describedby={guidanceId}
      placeholder={isReadingMode ? 'Escribe qué idea se quedó contigo…' : 'Escribe con calma…'}
      class="min-h-32 w-full resize-y rounded-2xl border border-stone-300 bg-white/70 p-4 leading-7 shadow-inner shadow-stone-100 transition duration-200 placeholder:text-stone-400 hover:border-stone-400 focus:border-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-600/20 dark:border-white/10 dark:bg-white/[0.025] dark:shadow-none dark:hover:border-white/20 dark:focus:border-amber-500"
    ></textarea>
    <p
      id={guidanceId}
      data-comment-guidance
      class:list={[isReadingMode ? 'mt-2 text-sm leading-6 text-stone-500 dark:text-stone-400' : 'hidden']}
    >
      {
        isReadingMode
          ? 'Inicia sesión con Google para publicar tu comentario.'
          : 'Tu comentario será revisado antes de publicarse.'
      }
    </p>
    <button
      data-comment-submit
      type="submit"
      class:list={[
        isReadingMode
          ? 'mt-3 min-h-11 rounded-full bg-stone-950 px-5 py-2.5 font-semibold text-white transition duration-200 hover:bg-stone-800 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-stone-950 disabled:cursor-wait disabled:opacity-60 dark:bg-stone-50 dark:text-stone-950 dark:hover:bg-white'
          : 'mt-3 rounded-full bg-stone-950 px-5 py-3 font-semibold text-white transition duration-300 hover:-translate-y-0.5 hover:bg-stone-800 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-stone-950 disabled:cursor-wait disabled:opacity-60 dark:bg-stone-50 dark:text-stone-950 dark:hover:bg-white',
        isReadingMode && 'hidden',
      ]}
    >
      Publicar comentario
    </button>
  </form>
  {isReadingMode && <div data-comments-auth class="mt-3" />}
  <p data-comments-message role="status" aria-live="polite" class="mt-4 hidden rounded-xl p-3 text-sm"></p>
  <div
    data-comments-list
    class:list={['min-h-6', isReadingMode ? 'mt-7' : 'mt-8 space-y-5']}
    aria-live="polite"
    aria-busy="true"
  >
    <p class="text-sm text-stone-500 dark:text-stone-400">Cargando comentarios…</p>
  </div>
</section>

<script>
  import { getCurrentUser, signInWithGoogle } from '~/features/auth/service';
  import { createComment, deleteComment, getApprovedComments, updateComment } from '~/features/comments/service';
  import { trackEvent } from '~/features/analytics/client';
  import type { Comment } from '~/features/comments/types';

  // Un proveedor bloqueado no debe dejar la conversación cargando indefinidamente ni afectar la lectura del artículo.
  const withInterfaceTimeout = <T,>(operation: Promise<T>, milliseconds: number) =>
    new Promise<T>((resolve, reject) => {
      const timeout = window.setTimeout(() => reject(new Error('La operación tardó demasiado.')), milliseconds);
      operation.then(
        (value) => {
          window.clearTimeout(timeout);
          resolve(value);
        },
        (error: unknown) => {
          window.clearTimeout(timeout);
          reject(error);
        }
      );
    });

  const initialize = async (root: Element) => {
    if (!(root instanceof HTMLElement) || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';
    const reflectionId = Number(root.dataset.reflectionId);
    const returnTo = root.dataset.returnTo || '/';
    const auth = root.querySelector('[data-comments-auth]');
    const form = root.querySelector('[data-comment-form]');
    const textarea = root.querySelector('[data-comment-content]');
    const guidance = root.querySelector('[data-comment-guidance]');
    const submitButton = root.querySelector('[data-comment-submit]');
    const list = root.querySelector('[data-comments-list]');
    const message = root.querySelector('[data-comments-message]');
    const isReadingMode = root.dataset.mode === 'reading';
    const sourceLocation = isReadingMode ? 'reading_conversation' : 'landing_conversation';
    let userId = '';
    let isAdmin = false;
    let hasTrackedFocus = false;

    const notify = (text: string, error = false) => {
      if (!(message instanceof HTMLElement)) return;
      message.textContent = text;
      message.className = `mt-4 rounded-xl border p-3 text-sm ${
        error
          ? 'border-red-200 bg-red-50 text-red-800 dark:border-red-900/60 dark:bg-red-950/30 dark:text-red-200'
          : 'border-emerald-200 bg-emerald-50 text-emerald-800 dark:border-emerald-900/60 dark:bg-emerald-950/30 dark:text-emerald-200'
      }`;
    };

    const load = async () => {
      if (!(list instanceof HTMLElement)) return;
      list.setAttribute('aria-busy', 'true');
      try {
        const comments = await withInterfaceTimeout(getApprovedComments(reflectionId), 8000);
        list.replaceChildren();
        if (!comments.length) {
          const empty = document.createElement('p');
          empty.className = isReadingMode ? 'text-sm leading-6 text-stone-500 dark:text-stone-400' : 'text-gray-500';
          empty.textContent = isReadingMode
            ? 'Todavía nadie ha iniciado la conversación. Tu reflexión podría ser la primera.'
            : 'Todavía no hay respuestas. Si algo resonó contigo, puedes iniciar la conversación.';
          list.append(empty);
          return;
        }
        comments.forEach((comment: Comment) => {
          const article = document.createElement('article');
          article.className = isReadingMode
            ? 'border-t border-stone-200 py-5 first:border-t-0 first:pt-0 dark:border-white/[0.08]'
            : 'rounded-2xl border border-gray-200 p-5 dark:border-gray-800';
          const header = document.createElement('div');
          header.className = 'flex items-center gap-3';
          if (comment.user_avatar) {
            const avatar = document.createElement('img');
            avatar.src = comment.user_avatar;
            avatar.alt = '';
            avatar.className = 'h-10 w-10 rounded-full object-cover';
            header.append(avatar);
          }
          const identity = document.createElement('div');
          const name = document.createElement('p');
          name.className = 'font-semibold';
          name.textContent = comment.user_name;
          const date = document.createElement('time');
          date.className = 'text-sm text-gray-500';
          date.dateTime = comment.created_at;
          date.textContent = new Intl.DateTimeFormat('es-PE', { dateStyle: 'medium' }).format(
            new Date(comment.created_at)
          );
          identity.append(name, date);
          header.append(identity);
          const content = document.createElement('p');
          content.className = isReadingMode
            ? 'mt-3 whitespace-pre-wrap leading-7 text-stone-700 dark:text-stone-300'
            : 'mt-4 whitespace-pre-wrap text-gray-700 dark:text-gray-300';
          content.textContent = comment.content;
          article.append(header, content);

          if (comment.user_id === userId || isAdmin) {
            const actions = document.createElement('div');
            actions.className = isReadingMode ? 'mt-3 flex gap-2 text-sm' : 'mt-4 flex gap-4 text-sm';
            const edit = document.createElement('button');
            edit.type = 'button';
            edit.textContent = 'Editar';
            const remove = document.createElement('button');
            remove.type = 'button';
            remove.textContent = 'Eliminar';
            edit.className = isReadingMode
              ? 'min-h-11 rounded-lg px-3 text-stone-600 hover:bg-stone-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-700 dark:text-stone-300 dark:hover:bg-white/[0.06]'
              : '';
            remove.className = isReadingMode
              ? 'min-h-11 rounded-lg px-3 text-red-700 hover:bg-red-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-700 dark:text-red-300 dark:hover:bg-red-950/30'
              : 'text-red-700';
            edit.classList.toggle('hidden', comment.user_id !== userId);
            edit.addEventListener('click', async () => {
              const next = window.prompt('Edita tu comentario', comment.content)?.trim();
              if (!next || next === comment.content) return;
              try {
                await updateComment(comment.id, next);
                await load();
              } catch (error) {
                notify(error instanceof Error ? error.message : 'No se pudo editar.', true);
              }
            });
            remove.addEventListener('click', async () => {
              if (!window.confirm('¿Eliminar este comentario?')) return;
              try {
                await deleteComment(comment.id);
                await load();
              } catch (error) {
                notify(error instanceof Error ? error.message : 'No se pudo eliminar.', true);
              }
            });
            actions.append(edit, remove);
            article.append(actions);
          }
          list.append(article);
        });
      } catch {
        list.replaceChildren();
        const failure = document.createElement('p');
        failure.className = 'text-sm text-stone-600 dark:text-stone-300';
        failure.textContent = 'No pudimos cargar la conversación. La reflexión sigue disponible.';
        const retry = document.createElement('button');
        retry.type = 'button';
        retry.className =
          'mt-2 min-h-11 rounded-lg px-3 text-sm font-semibold text-amber-800 hover:bg-amber-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-700 dark:text-amber-300 dark:hover:bg-amber-950/20';
        retry.textContent = 'Intentar de nuevo';
        retry.addEventListener('click', load);
        list.append(failure, retry);
      } finally {
        list.setAttribute('aria-busy', 'false');
      }
    };

    const renderLogin = () => {
      if (!(auth instanceof HTMLElement)) return;
      auth.replaceChildren();
      const login = document.createElement('button');
      login.type = 'button';
      login.className = isReadingMode
        ? 'min-h-11 rounded-full border border-stone-300 px-5 py-2.5 font-semibold text-stone-800 transition duration-200 hover:border-stone-400 hover:bg-stone-50 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-amber-700 disabled:cursor-wait disabled:opacity-60 dark:border-white/15 dark:text-stone-100 dark:hover:border-white/25 dark:hover:bg-white/[0.04]'
        : 'rounded-full border border-gray-300 px-5 py-3 font-semibold dark:border-gray-700';
      login.textContent = 'Continuar con Google';
      login.addEventListener('click', async () => {
        trackEvent('comment_login_click', {
          reflection_slug: root.dataset.reflectionSlug || '',
          authenticated: false,
          source_location: sourceLocation,
        });
        login.disabled = true;
        login.textContent = 'Abriendo Google…';
        try {
          await signInWithGoogle(returnTo);
        } catch {
          login.disabled = false;
          login.textContent = 'Continuar con Google';
          notify('No pudimos iniciar sesión. Puedes intentarlo de nuevo.', true);
        }
      });
      auth.append(login);
    };

    // Sesión y comentarios son independientes: cargarlos en paralelo evita que un proveedor lento bloquee al otro.
    const commentsLoad = load();

    try {
      const user = await withInterfaceTimeout(getCurrentUser(), 6000);
      if (user && !user.is_anonymous) {
        userId = user.id;
        isAdmin = Boolean(import.meta.env.PUBLIC_ADMIN_EMAIL && user.email === import.meta.env.PUBLIC_ADMIN_EMAIL);
        form?.classList.remove('hidden');
        if (textarea instanceof HTMLTextAreaElement) {
          textarea.readOnly = false;
          textarea.removeAttribute('aria-disabled');
        }
        submitButton?.classList.remove('hidden');
        if (isReadingMode && guidance instanceof HTMLElement)
          guidance.textContent = 'Tu comentario será revisado antes de publicarse.';
        if (auth instanceof HTMLElement && textarea instanceof HTMLTextAreaElement) {
          if (isReadingMode) {
            // La identidad acompaña el campo sin desplazar la invitación; Google deja de ocupar este lugar tras OAuth.
            textarea.before(auth);
            auth.className = 'mb-2 text-sm text-stone-500 dark:text-stone-400';
          }
          auth.textContent = `Comentas como ${String(user.user_metadata.full_name ?? user.email ?? 'lector')}.`;
        }
      } else {
        renderLogin();
      }
    } catch {
      notify('No pudimos comprobar tu sesión. Puedes volver a intentarlo.', true);
      renderLogin();
    }

    textarea?.addEventListener('focus', () => {
      if (!hasTrackedFocus) {
        hasTrackedFocus = true;
        trackEvent('comment_form_focus', {
          reflection_slug: root.dataset.reflectionSlug || '',
          authenticated: Boolean(userId),
          source_location: sourceLocation,
        });
      }
      if (!userId && auth instanceof HTMLElement) {
        auth.classList.add('rounded-xl', 'ring-2', 'ring-amber-600/20', 'ring-offset-4', 'dark:ring-offset-stone-950');
        window.setTimeout(
          () =>
            auth.classList.remove(
              'rounded-xl',
              'ring-2',
              'ring-amber-600/20',
              'ring-offset-4',
              'dark:ring-offset-stone-950'
            ),
          1400
        );
      }
    });

    // El fragmento conserva el contexto tras OAuth y devuelve el foco al punto donde el lector quería participar.
    if (isReadingMode && window.location.hash === '#conversacion' && textarea instanceof HTMLTextAreaElement) {
      window.requestAnimationFrame(() => textarea.focus({ preventScroll: true }));
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!(textarea instanceof HTMLTextAreaElement) || !textarea.value.trim()) return;
      const button = submitButton instanceof HTMLButtonElement ? submitButton : null;
      if (button) {
        button.disabled = true;
        button.textContent = 'Publicando…';
      }
      trackEvent('comment_submit', {
        reflection_slug: root.dataset.reflectionSlug || '',
        authenticated: true,
        moderation_status: 'pending',
        source_location: sourceLocation,
      });
      try {
        await createComment(reflectionId, textarea.value);
        textarea.value = '';
        notify('Gracias. Tu comentario fue enviado y será revisado antes de publicarse.');
        trackEvent('comment_submit_success', {
          reflection_slug: root.dataset.reflectionSlug || '',
          authenticated: true,
          moderation_status: 'pending',
          source_location: sourceLocation,
        });
      } catch {
        notify('No pudimos publicar tu comentario. El texto sigue aquí para que puedas intentarlo de nuevo.', true);
        trackEvent('comment_submit_error', {
          reflection_slug: root.dataset.reflectionSlug || '',
          authenticated: true,
          moderation_status: 'error',
          source_location: sourceLocation,
        });
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = 'Publicar comentario';
        }
      }
    });
    await commentsLoad;
  };

  const initializeAll = () => document.querySelectorAll('[data-comments-root]').forEach(initialize);
  initializeAll();
  document.addEventListener('astro:page-load', initializeAll);
</script>
