---
/*
====================================================
Analytics

Responsabilidad
Cargar GA4 de forma opcional y conectar page views SSR/ClientRouter con la capa interna de producto.

Dependencias
PUBLIC_GA_MEASUREMENT_ID y cliente central de Analytics.

Qué no debe hacer
No carga scripts sin configuración, no registra rutas privadas y no bloquea el render.

Autor: Daniel Montesinos
====================================================
*/

import AnalyticsClient from '~/components/analytics/AnalyticsClient.astro';

const isPrivateRoute =
  Astro.url.pathname === '/admin' ||
  Astro.url.pathname.startsWith('/admin/') ||
  Astro.url.pathname === '/auth' ||
  Astro.url.pathname.startsWith('/auth/');
const measurementId = isPrivateRoute ? '' : import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';
---

{
  measurementId && (
    <>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`} />
      <AnalyticsClient measurementId={measurementId} />
    </>
  )
}
