---
/*
====================================================
SiteFooter

Responsabilidad
Cerrar el recorrido con la intensidad adecuada a cada página.

Qué hace
La variante predeterminada presenta el cierre emocional; ambas variantes conservan marca, navegación, canales activos
y derechos para ofrecer un siguiente paso sin convertir el pie en un mapa corporativo.

Qué no hace
No contiene lógica de negocio, no inventa enlaces sociales y no sustituye la navegación principal.

Dependencias
Configuración pública tipada y la misma resolución de navegación utilizada por SiteHeader.

Decisión de diseño
`compact` evita dos despedidas consecutivas. `landing` conserva una sola idea final y reduce altura sin cambiar el pie
del resto del sitio; ambas variantes comparten navegación, marca y accesibilidad.

Cómo extenderlo
Puede incorporar enlaces legales cuando existan rutas reales, pero nunca debe generar destinos ficticios.

Autor: Daniel Montesinos
====================================================
*/

import type { SiteConfig } from '~/config/site';
import { resolveSiteNavigation } from '~/utils/navigation';

export interface Props {
  brand: SiteConfig['brand'];
  footer: SiteConfig['footer'];
  navigation: SiteConfig['navigation'];
  social: SiteConfig['social'];
  currentPath: string;
  variant?: 'default' | 'compact' | 'landing';
}

const { brand, footer, navigation, social, currentPath, variant = 'default' } = Astro.props;
const isCompact = variant === 'compact';
const isLanding = variant === 'landing';
const navigationItems = resolveSiteNavigation(navigation, currentPath);
const activeSocialLinks = social.links.filter(
  (link: SiteConfig['social']['links'][number]) => link.available && link.href
);
---

<footer
  id="footer"
  class:list={[
    'border-t border-stone-200 px-6 dark:border-white/[0.07]',
    isCompact ? 'py-8 sm:py-10' : isLanding ? 'editorial-closing py-9 sm:py-10' : 'editorial-closing py-12 sm:py-14',
  ]}
>
  {
    !isCompact && (
      <div class:list={['mx-auto max-w-2xl text-center', isLanding && 'pb-1']}>
        {!isLanding && (
          <span aria-hidden="true" class="text-base text-amber-700/60 dark:text-amber-400/50">
            ✦
          </span>
        )}
        <p
          class:list={[
            'font-semibold tracking-tight text-stone-950 dark:text-stone-50',
            isLanding ? 'text-lg sm:text-xl' : 'mt-4 text-xl sm:text-2xl',
          ]}
        >
          {footer.title}
        </p>
        {!isLanding && (
          <>
            <p class="mt-4 text-pretty text-sm leading-6 text-stone-600 dark:text-stone-400 sm:text-base sm:leading-7">
              {footer.message}
            </p>
            <p class="mt-4 text-sm font-medium text-stone-800 dark:text-stone-300">{footer.signature}</p>
          </>
        )}
      </div>
    )
  }
  <div
    class:list={[
      'mx-auto flex max-w-7xl flex-col gap-6 text-sm sm:flex-row sm:items-center sm:justify-between',
      !isCompact &&
        (isLanding
          ? 'mt-6 border-t border-stone-200/70 pt-6 dark:border-white/[0.07]'
          : 'mt-10 border-t border-stone-200/70 pt-8 dark:border-white/[0.07]'),
    ]}
  >
    <div>
      <p class="font-semibold tracking-tight text-stone-950 dark:text-stone-50">{brand.name}</p>
      <p class="mt-1 text-xs text-stone-400">© {new Date().getFullYear()} Todos los derechos reservados.</p>
    </div>
    <nav aria-label="Navegación del pie de página">
      <ul class="flex flex-wrap gap-x-5 gap-y-1">
        {
          navigationItems.map((item) => (
            <li>
              <a
                href={item.resolvedHref}
                aria-current={item.isCurrent ? 'page' : undefined}
                class:list={[
                  'inline-flex min-h-11 items-center rounded-sm transition hover:text-stone-950 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-stone-950 dark:hover:text-stone-100',
                  item.isCurrent
                    ? 'font-semibold text-stone-800 dark:text-stone-200'
                    : 'text-stone-500 dark:text-stone-400',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="flex flex-wrap gap-x-5 gap-y-1" aria-label="Canales activos">
      {
        activeSocialLinks.map((link: SiteConfig['social']['links'][number]) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class="inline-flex min-h-11 items-center rounded-sm text-stone-500 transition hover:text-stone-950 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-stone-950 dark:text-stone-400 dark:hover:text-stone-100"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
