---
/*
====================================================
SiteHeader

Responsabilidad
Presentar la marca y la navegación principal del sitio.

Qué hace
Resuelve destinos consistentes, comunica la página activa y ofrece un menú móvil nativo de un solo nivel.

Qué no hace
No gestiona autenticación, datos remotos ni estado global.

Dependencias
Configuración pública tipada y utilidad compartida de resolución de navegación.

Decisiones de interacción
El header reduce solo ocho píxeles después del primer tramo de scroll: conserva orientación sin competir con la lectura.
El menú móvil usa `details`, mejora progresivamente con cierre exterior y devuelve el foco al activador con Escape.

Autor: Daniel Montesinos
====================================================
*/

import type { SiteConfig } from '~/config/site';
import { resolveSiteNavigation } from '~/utils/navigation';

export interface Props {
  brand: SiteConfig['brand'];
  navigation: SiteConfig['navigation'];
  currentPath: string;
}

const { brand, navigation, currentPath } = Astro.props;
const navigationItems = resolveSiteNavigation(navigation, currentPath);
---

<header
  data-site-header
  data-scrolled="false"
  class="sticky top-0 z-40 border-b border-stone-200/70 bg-white/90 backdrop-blur-xl dark:border-stone-800 dark:bg-stone-950/90"
>
  <div
    data-header-inner
    class="mx-auto flex min-h-16 max-w-7xl items-center justify-between px-5 transition-[min-height] duration-300 sm:px-6"
  >
    <a
      href="/"
      class="rounded-sm text-base font-semibold tracking-tight text-stone-950 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-stone-950 dark:text-stone-50"
      >{brand.name}</a
    >
    <nav aria-label="Navegación principal" class="hidden sm:block">
      <ul class="flex items-center gap-7">
        {
          navigationItems.map((item) => (
            <li>
              <a
                href={item.resolvedHref}
                aria-current={item.isCurrent ? 'page' : undefined}
                class:list={[
                  'relative inline-flex min-h-11 items-center rounded-sm text-sm font-medium transition duration-300 hover:text-stone-950 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-stone-950 dark:hover:text-white',
                  item.isCurrent
                    ? 'text-stone-950 after:absolute after:inset-x-0 after:bottom-1 after:h-px after:bg-amber-700 dark:text-white dark:after:bg-amber-400'
                    : 'text-stone-600 dark:text-stone-300',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <details data-mobile-navigation class="relative sm:hidden">
      <summary
        aria-controls="mobile-navigation-menu"
        aria-expanded="false"
        class="cursor-pointer list-none rounded-full border border-stone-200 px-4 py-2 text-sm font-semibold marker:content-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-950 dark:border-stone-700"
        >Menú</summary
      >
      <nav
        id="mobile-navigation-menu"
        aria-label="Navegación móvil"
        class="absolute right-0 top-12 w-52 rounded-2xl border border-stone-200 bg-white p-2 shadow-xl dark:border-stone-800 dark:bg-stone-900"
      >
        <ul>
          {
            navigationItems.map((item) => (
              <li>
                <a
                  href={item.resolvedHref}
                  aria-current={item.isCurrent ? 'page' : undefined}
                  class:list={[
                    'block min-h-11 rounded-xl px-4 py-3 text-sm font-medium transition hover:bg-stone-100 focus-visible:outline-2 focus-visible:outline-stone-950 dark:hover:bg-stone-800',
                    item.isCurrent && 'bg-stone-100 text-stone-950 dark:bg-stone-800 dark:text-white',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </details>
  </div>
</header>

<script>
  declare global {
    interface Window {
      cleanupSiteNavigation?: () => void;
    }
  }

  /**
   * Mantiene únicamente estado efímero de interfaz. Se reinicia en cada navegación de Astro para no acumular
   * listeners cuando ClientRouter reemplaza la página sin una recarga completa.
   */
  const initializeSiteNavigation = () => {
    window.cleanupSiteNavigation?.();

    const header = document.querySelector('[data-site-header]');
    const mobileNavigation = header?.querySelector('[data-mobile-navigation]');
    const summary = mobileNavigation?.querySelector('summary');
    if (!(header instanceof HTMLElement)) return;

    const controller = new AbortController();
    const { signal } = controller;
    let animationFrame = 0;

    const updateHeaderDensity = () => {
      header.dataset.scrolled = String(window.scrollY > 24);
      animationFrame = 0;
    };

    const requestHeaderDensityUpdate = () => {
      if (!animationFrame) animationFrame = window.requestAnimationFrame(updateHeaderDensity);
    };

    /**
     * Astro sustituye el documento durante una navegación interna. Esperar dos frames permite que el destino
     * exista y tenga su altura definitiva. En ese instante evitamos heredar temporalmente el scroll suave del
     * documento: una animación que recorra toda una página interna tarda varios segundos y desorienta. Los enlaces
     * entre secciones de la propia Home conservan su desplazamiento suave mediante CSS.
     */
    const alignRequestedHomeSection = () => {
      if (window.location.pathname !== '/' || !window.location.hash) return;

      const sectionId = window.location.hash.slice(1);
      const targetSection = document.getElementById(sectionId);
      if (!targetSection) return;

      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => {
          const previousScrollBehavior = document.documentElement.style.scrollBehavior;
          document.documentElement.style.scrollBehavior = 'auto';
          targetSection.scrollIntoView({ behavior: 'auto', block: 'start' });
          window.requestAnimationFrame(() => {
            document.documentElement.style.scrollBehavior = previousScrollBehavior;
          });
        });
      });
    };

    if (mobileNavigation instanceof HTMLDetailsElement && summary instanceof HTMLElement) {
      const closeMobileNavigation = (restoreFocus = false) => {
        mobileNavigation.open = false;
        if (restoreFocus) summary.focus();
      };

      mobileNavigation.addEventListener(
        'toggle',
        () => summary.setAttribute('aria-expanded', String(mobileNavigation.open)),
        { signal }
      );
      mobileNavigation.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => closeMobileNavigation(), { signal });
      });
      document.addEventListener(
        'pointerdown',
        (event) => {
          if (mobileNavigation.open && !mobileNavigation.contains(event.target as Node)) closeMobileNavigation();
        },
        { signal }
      );
      document.addEventListener(
        'keydown',
        (event) => {
          if (event.key === 'Escape' && mobileNavigation.open) {
            event.preventDefault();
            closeMobileNavigation(true);
          }
        },
        { signal }
      );
    }

    updateHeaderDensity();
    alignRequestedHomeSection();
    window.addEventListener('scroll', requestHeaderDensityUpdate, { passive: true, signal });
    window.cleanupSiteNavigation = () => {
      controller.abort();
      if (animationFrame) window.cancelAnimationFrame(animationFrame);
    };
  };

  initializeSiteNavigation();
  document.addEventListener('astro:page-load', initializeSiteNavigation);
</script>

<style>
  [data-site-header][data-scrolled='true'] [data-header-inner] {
    min-height: 3.5rem;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-header-inner] {
      transition: none;
    }
  }
</style>
