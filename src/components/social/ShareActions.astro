---
/*
====================================================
ShareActions

Responsabilidad
Permitir compartir una reflexión sin convertir las redes en protagonistas de la lectura.

Qué renderiza
Enlaces accesibles para WhatsApp, LinkedIn, Facebook y X, además de una acción para copiar la URL canónica.

Datos que recibe
URL canónica, título y descripción reales de la reflexión.

Dependencias
APIs nativas del navegador. No instala SDK ni librerías sociales.

Qué no debe hacer
No registra métricas, no consulta Supabase y no abre popups automáticos.

Decisión de accesibilidad
Cada destino es un enlace normal utilizable con teclado. La copia informa el resultado mediante una región aria-live;
si Clipboard API no está disponible, se ofrece una instrucción clara sin recurrir a APIs obsoletas o diálogos invasivos.

Autor: Daniel Montesinos
====================================================
*/

export interface Props {
  canonicalUrl: string;
  title: string;
  description: string;
}

const { canonicalUrl, title, description } = Astro.props;
const encodedUrl = encodeURIComponent(canonicalUrl);
const encodedTitle = encodeURIComponent(title);
const encodedMessage = encodeURIComponent(`${title}\n\n${description}\n${canonicalUrl}`);
const destinations = [
  { label: 'WhatsApp', href: `https://wa.me/?text=${encodedMessage}` },
  { label: 'LinkedIn', href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}` },
  { label: 'Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}` },
  { label: 'X', href: `https://x.com/intent/post?url=${encodedUrl}&text=${encodedTitle}` },
] as const;
---

<div data-share-root data-share-url={canonicalUrl} class="w-full">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500 dark:text-stone-400">
    Compartir esta reflexión
  </p>
  <div class="mt-3 flex flex-wrap gap-2">
    {
      destinations.map((destination) => (
        <a
          href={destination.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-11 items-center rounded-full border border-stone-300/80 bg-white/35 px-4 py-2 text-sm font-medium text-stone-600 transition duration-200 hover:border-stone-500 hover:bg-white/70 hover:text-stone-950 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-stone-950 dark:border-white/12 dark:bg-white/[0.025] dark:text-stone-300 dark:hover:border-white/25 dark:hover:bg-white/[0.055] dark:hover:text-stone-50"
          aria-label={`Compartir en ${destination.label}; se abre en una pestaña nueva`}
        >
          {destination.label}
        </a>
      ))
    }
    <button
      type="button"
      data-copy-link
      class="inline-flex min-h-11 items-center rounded-full border border-stone-300/80 bg-white/35 px-4 py-2 text-sm font-medium text-stone-600 transition duration-200 hover:border-stone-500 hover:bg-white/70 hover:text-stone-950 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-stone-950 dark:border-white/12 dark:bg-white/[0.025] dark:text-stone-300 dark:hover:border-white/25 dark:hover:bg-white/[0.055] dark:hover:text-stone-50"
    >
      Copiar enlace
    </button>
  </div>
  <p data-copy-status class="mt-2 min-h-5 text-sm text-stone-500 dark:text-stone-400" aria-live="polite"></p>
</div>

<script>
  /**
   * Clipboard API funciona en el contexto HTTPS de producción. Fallar de forma explícita en navegadores antiguos evita
   * depender de execCommand —obsoleto— y permite que la región aria-live explique cómo copiar manualmente.
   */
  const copyText = async (text: string) => {
    if (!navigator.clipboard?.writeText) throw new Error('Clipboard API no disponible.');
    await navigator.clipboard.writeText(text);
  };

  const initializeShareActions = (root: Element) => {
    if (!(root instanceof HTMLElement) || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';
    const button = root.querySelector('[data-copy-link]');
    const status = root.querySelector('[data-copy-status]');
    if (!(button instanceof HTMLButtonElement) || !(status instanceof HTMLElement)) return;

    button.addEventListener('click', async () => {
      button.disabled = true;
      try {
        await copyText(root.dataset.shareUrl || window.location.href);
        status.textContent = 'Enlace copiado.';
      } catch {
        status.textContent = 'No pudimos copiarlo. Puedes copiar la dirección desde el navegador.';
      } finally {
        button.disabled = false;
      }
    });
  };

  const initializeAllShareActions = () =>
    document.querySelectorAll('[data-share-root]').forEach(initializeShareActions);

  initializeAllShareActions();
  document.addEventListener('astro:page-load', initializeAllShareActions);
</script>
