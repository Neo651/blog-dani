---
/*
====================================================
SocialSection

Responsabilidad
Ofrecer una continuación natural de la conversación fuera del blog.

Qué renderiza
Canales compactos con su estado actual. Landing prioriza cuatro; la página personal puede incluir canales secundarios.

Datos que recibe
Copy, enlaces sociales y una variante de superficie procedentes de la configuración pública centralizada.

Dependencias
SocialIcon y configuración pública tipada del sitio.

Qué no debe hacer
No muestra métricas sociales, no contiene URLs propias y no crea enlaces ficticios.

Decisión de diseño
Esta sección cierra opciones de contacto sin convertirse en otro destino principal: usa bajo contraste, poca altura y movimiento mínimo.

Cómo extenderlo
Los nuevos canales se incorporan desde configuración. El componente no debe crecer visualmente; si aparecen muchos canales,
deberán priorizarse allí en lugar de añadir filas indiscriminadamente.

Autor: Daniel Montesinos
====================================================
*/

import SocialIcon from '~/components/social/SocialIcon.astro';
import type { SiteConfig } from '~/config/site';

export interface Props {
  social: SiteConfig['social'];
  variant?: 'landing' | 'profile';
}

const { social, variant = 'landing' } = Astro.props;
const isLanding = variant === 'landing';

// La prioridad vive en configuración para poder mover GitHub u otra red sin rediseñar el componente.
const visibleSocialLinks = isLanding ? social.links.filter((link) => link.priority) : social.links;
---

<section
  class:list={['relative overflow-hidden px-5 sm:px-6', isLanding ? 'py-10 sm:py-12 lg:py-14' : 'py-16 sm:py-20']}
>
  <div class="mx-auto max-w-5xl">
    <div
      id={isLanding ? 'contacto' : 'redes'}
      class:list={['max-w-xl', isLanding && 'landing-anchor landing-section-reveal']}
    >
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-stone-500 dark:text-stone-400 sm:text-sm">
        {social.eyebrow}
      </p>
      <h2 class="mt-3 text-2xl font-semibold tracking-[-0.025em] text-stone-950 dark:text-stone-50 sm:text-3xl">
        {social.title}
      </h2>
      <p class="mt-2 text-sm leading-6 text-stone-600 dark:text-stone-400">{social.description}</p>
    </div>

    <ul class:list={['mt-5 grid grid-cols-2 gap-2.5', isLanding ? 'lg:grid-cols-4' : 'sm:grid-cols-2 lg:grid-cols-5']}>
      {
        visibleSocialLinks.map((link: SiteConfig['social']['links'][number]) => (
          <li class="min-w-0">
            {link.available && link.href ? (
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                class="group flex h-full min-h-24 flex-col rounded-xl border border-stone-200/80 bg-white/55 p-3.5 text-stone-800 transition duration-300 hover:border-amber-300 hover:bg-amber-50/40 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-amber-600 dark:border-white/[0.065] dark:bg-white/[0.018] dark:text-stone-200 dark:hover:border-amber-800/60 dark:hover:bg-amber-950/10"
              >
                <span class="flex items-center justify-between">
                  <span class="grid h-7 w-7 place-items-center rounded-lg bg-stone-100 text-stone-500 transition duration-300 group-hover:bg-amber-100 group-hover:text-amber-800 dark:bg-white/[0.045] dark:text-stone-400 dark:group-hover:bg-amber-900/25 dark:group-hover:text-amber-300">
                    <SocialIcon name={link.icon} />
                  </span>
                  <span
                    aria-hidden="true"
                    class="text-base text-stone-400 transition duration-300 group-hover:translate-x-0.5 group-hover:text-amber-700 dark:text-stone-600 dark:group-hover:text-amber-300"
                  >
                    ↗
                  </span>
                </span>
                <span class="mt-2.5 text-sm font-semibold">{link.label}</span>
                <span class="mt-1 text-xs leading-5 text-stone-500 dark:text-stone-400">{link.description}</span>
              </a>
            ) : (
              /* Una red sin URL se presenta como próxima; nunca se genera un destino falso o no navegable. */
              <div class="flex h-full min-h-24 flex-col rounded-xl border border-dashed border-stone-200/80 bg-stone-50/30 p-3.5 text-stone-500 transition duration-300 hover:border-stone-300 dark:border-white/[0.065] dark:bg-white/[0.012] dark:text-stone-500 dark:hover:border-white/15">
                <span class="flex items-center justify-between gap-2">
                  <span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-stone-100 text-stone-400 dark:bg-white/[0.04] dark:text-stone-500">
                    <SocialIcon name={link.icon} />
                  </span>
                  <span class="rounded-full border border-stone-200 px-2 py-1 text-[0.625rem] font-semibold uppercase tracking-[0.12em] text-stone-400 dark:border-white/10 dark:text-stone-500">
                    Próximamente
                  </span>
                </span>
                <span class="mt-2.5 text-sm font-semibold text-stone-600 dark:text-stone-400">{link.label}</span>
                <span class="mt-1 text-xs leading-5">{link.description}</span>
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>
