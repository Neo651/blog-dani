---
/*
====================================================
SocialSection

Responsabilidad
Ofrecer una continuación natural de la conversación fuera del blog.

Qué renderiza
Canales compactos con su estado actual. Landing prioriza cuatro; la página personal puede incluir canales secundarios.

Datos que recibe
Copy, enlaces sociales y una variante de superficie procedentes de la configuración pública centralizada.

Dependencias
SocialIcon y configuración pública tipada del sitio.

Qué no debe hacer
No muestra métricas sociales, no contiene URLs propias y no crea enlaces ficticios.

Decisión de diseño
Esta sección cierra opciones de contacto sin convertirse en otro destino principal: usa bajo contraste, poca altura y movimiento mínimo.

Cómo extenderlo
Los nuevos canales se incorporan desde configuración. El componente no debe crecer visualmente; si aparecen muchos canales,
deberán priorizarse allí en lugar de añadir filas indiscriminadamente.

Autor: Daniel Montesinos
====================================================
*/

import SocialIcon from '~/components/social/SocialIcon.astro';
import type { SiteConfig } from '~/config/site';

export interface Props {
  social: SiteConfig['social'];
  variant?: 'landing' | 'profile';
}

const { social, variant = 'landing' } = Astro.props;
const isLanding = variant === 'landing';

// La prioridad vive en configuración para poder mover GitHub u otra red sin rediseñar el componente.
const visibleSocialLinks = isLanding ? social.links.filter((link) => link.priority) : social.links;
---

<section class:list={['relative overflow-hidden px-5 sm:px-6', isLanding ? 'py-8 sm:py-9 lg:py-10' : 'py-16 sm:py-20']}>
  <div class:list={['mx-auto', isLanding ? 'max-w-4xl' : 'max-w-5xl']}>
    <div
      id={isLanding ? 'contacto' : 'redes'}
      class:list={[
        'max-w-xl',
        isLanding &&
          'landing-anchor intersect-once intersect-quarter motion-safe:opacity-0 motion-safe:intersect:animate-fade',
      ]}
    >
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-stone-500 dark:text-stone-400 sm:text-sm">
        {social.eyebrow}
      </p>
      <h2
        class:list={[
          'text-2xl font-semibold tracking-[-0.025em] text-stone-950 dark:text-stone-50',
          isLanding ? 'mt-2.5' : 'mt-3 sm:text-3xl',
        ]}
      >
        {social.title}
      </h2>
      <p class="mt-2 text-sm leading-6 text-stone-600 dark:text-stone-400">{social.description}</p>
    </div>

    <ul
      class:list={[
        'grid grid-cols-2',
        isLanding ? 'mt-4 gap-2 lg:grid-cols-4' : 'mt-5 gap-2.5 sm:grid-cols-2 lg:grid-cols-5',
      ]}
    >
      {
        visibleSocialLinks.map((link: SiteConfig['social']['links'][number]) => (
          <li class="min-w-0">
            {link.available && link.href ? (
              <a
                href={link.href}
                data-analytics-cta={
                  link.label === 'LinkedIn' ? 'linkedin' : link.label === 'Correo' ? 'correo' : undefined
                }
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                class:list={[
                  'group flex h-full flex-col rounded-xl border text-stone-800 transition duration-300 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-amber-600 dark:text-stone-200',
                  isLanding
                    ? 'min-h-20 border-stone-200/70 bg-white/45 p-3 hover:border-amber-300/80 hover:bg-amber-50/30 dark:border-white/[0.055] dark:bg-white/[0.014] dark:hover:border-amber-800/45 dark:hover:bg-amber-950/[0.07]'
                    : 'min-h-24 border-stone-200/80 bg-white/55 p-3.5 hover:border-amber-300 hover:bg-amber-50/40 dark:border-white/[0.065] dark:bg-white/[0.018] dark:hover:border-amber-800/60 dark:hover:bg-amber-950/10',
                ]}
              >
                <span class="flex items-center justify-between">
                  <span
                    class:list={[
                      'grid place-items-center bg-stone-100 text-stone-500 transition duration-300 group-hover:bg-amber-100 group-hover:text-amber-800 dark:text-stone-400 dark:group-hover:text-amber-300',
                      isLanding
                        ? 'h-6 w-6 rounded-md dark:bg-white/[0.04] dark:group-hover:bg-amber-900/20'
                        : 'h-7 w-7 rounded-lg dark:bg-white/[0.045] dark:group-hover:bg-amber-900/25',
                    ]}
                  >
                    <SocialIcon name={link.icon} />
                  </span>
                  <span
                    aria-hidden="true"
                    class:list={[
                      'text-base text-stone-400 transition duration-300 group-hover:translate-x-0.5 group-hover:text-amber-700 dark:text-stone-600 dark:group-hover:text-amber-300',
                      isLanding && 'motion-reduce-landing-transform',
                    ]}
                  >
                    ↗
                  </span>
                </span>
                <span class:list={['text-sm font-semibold', isLanding ? 'mt-2' : 'mt-2.5']}>{link.label}</span>
                <span class="mt-1 text-xs leading-5 text-stone-500 dark:text-stone-400">{link.description}</span>
              </a>
            ) : (
              /* Una red sin URL se presenta como próxima; nunca se genera un destino falso o no navegable. */
              <div
                class:list={[
                  'flex h-full flex-col rounded-xl border border-dashed text-stone-500 transition duration-300 hover:border-stone-300 dark:text-stone-500',
                  isLanding
                    ? 'min-h-20 border-stone-200/70 bg-stone-50/20 p-3 dark:border-white/[0.055] dark:bg-white/[0.01] dark:hover:border-white/12'
                    : 'min-h-24 border-stone-200/80 bg-stone-50/30 p-3.5 dark:border-white/[0.065] dark:bg-white/[0.012] dark:hover:border-white/15',
                ]}
              >
                <span class="flex items-center justify-between gap-2">
                  <span
                    class:list={[
                      'grid shrink-0 place-items-center bg-stone-100 text-stone-400 dark:text-stone-500',
                      isLanding
                        ? 'h-6 w-6 rounded-md dark:bg-white/[0.035]'
                        : 'h-7 w-7 rounded-lg dark:bg-white/[0.04]',
                    ]}
                  >
                    <SocialIcon name={link.icon} />
                  </span>
                  <span class="rounded-full border border-stone-200 px-2 py-1 text-[0.625rem] font-semibold uppercase tracking-[0.12em] text-stone-400 dark:border-white/10 dark:text-stone-500">
                    Próximamente
                  </span>
                </span>
                <span
                  class:list={[
                    'text-sm font-semibold text-stone-600 dark:text-stone-400',
                    isLanding ? 'mt-2' : 'mt-2.5',
                  ]}
                >
                  {link.label}
                </span>
                <span class="mt-1 text-xs leading-5">{link.description}</span>
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>
