---
import Layout from '~/layouts/Layout.astro';
const returnTo = Astro.url.searchParams.get('returnTo');
const safeReturnTo = returnTo?.startsWith('/') && !returnTo.startsWith('//') ? returnTo : '/';
---

<Layout metadata={{ title: 'Completando inicio de sesión', robots: { index: false, follow: false } }}>
  <main data-auth-callback data-return-to={safeReturnTo} class="grid min-h-screen place-items-center px-6 text-center">
    <div>
      <h1 class="text-2xl font-bold">Completando inicio de sesión…</h1>
      <p class="mt-3 text-gray-500">Enseguida volverás a la reflexión.</p>
    </div>
  </main>
</Layout>

<script>
  import { getSupabaseBrowserClient } from '~/lib/supabase/client';
  const root = document.querySelector('[data-auth-callback]');
  const safeReturnTo = root instanceof HTMLElement ? root.dataset.returnTo || '/' : '/';
  const client = getSupabaseBrowserClient();
  client.auth.getSession().finally(() => window.location.replace(safeReturnTo));
</script>
