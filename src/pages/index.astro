---
import AboutSection from '~/components/about/AboutSection.astro';
import CommentsSection from '~/components/comments/CommentsSection.astro';
import HeroSection from '~/components/home/HeroSection.astro';
import ReflectionCard from '~/components/reflections/ReflectionCard.astro';
import ReflectionFeature from '~/components/reflections/ReflectionFeature.astro';
import SocialSection from '~/components/social/SocialSection.astro';
import { siteConfig } from '~/config/site';
import { getApprovedCommentCounts } from '~/features/comments/service';
import { getLikeCounts } from '~/features/likes/service';
import { getLandingReflections } from '~/features/reflections/service';
import type { Reflection } from '~/features/reflections/types';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: `${siteConfig.brand.name} | ${siteConfig.brand.tagline}`,
  ignoreTitleTemplate: true,
  description: siteConfig.brand.description,
  canonical: siteConfig.brand.siteUrl,
};
const websiteStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.brand.name,
  url: siteConfig.brand.siteUrl,
  description: siteConfig.brand.description,
  inLanguage: 'es-PE',
  author: { '@type': 'Person', name: siteConfig.brand.name, url: `${siteConfig.brand.siteUrl}/sobre-mi` },
};
const websiteStructuredDataJson = JSON.stringify(websiteStructuredData).replace(/</g, '\\u003c');

let reflections: Reflection[] = [];
let loadError = false;
let likeCounts = new Map<number, number>();
let commentCounts = new Map<number, number>();
let engagementAvailable = true;

try {
  reflections = await getLandingReflections();
  const previousIds = reflections.slice(1, 4).map(({ id }) => id);
  if (previousIds.length) {
    try {
      [likeCounts, commentCounts] = await Promise.all([
        getLikeCounts(previousIds),
        getApprovedCommentCounts(previousIds),
      ]);
    } catch (error) {
      console.warn('No se pudieron cargar las métricas de la Landing', error);
      engagementAvailable = false;
    }
  }
} catch (error) {
  console.error('No se pudo construir la experiencia de la Home', error);
  loadError = true;
}

const latest = reflections[0];
const previous = reflections.slice(1, 4);
---

<Layout metadata={metadata}>
  <script type="application/ld+json" is:inline set:html={websiteStructuredDataJson} />
  <div class="landing-surface">
    <HeroSection hero={siteConfig.hero} />

    <div class="px-5 sm:px-6">
      {
        loadError ? (
          <section class="mx-auto mb-24 max-w-3xl rounded-3xl border border-red-200 bg-red-50 p-8 text-center text-red-800 dark:border-red-950 dark:bg-red-950/20 dark:text-red-200">
            <h2 class="text-2xl font-semibold">No pudimos cargar las reflexiones</h2>
            <p class="mt-3">Inténtalo de nuevo en unos minutos. Este espacio seguirá aquí cuando regreses.</p>
          </section>
        ) : latest ? (
          <section class="reading-conversation-flow mx-auto max-w-6xl pb-16 sm:pb-20 lg:pb-24">
            <div id="reflexion-destacada" class="landing-anchor mb-8 max-w-2xl">
              <p class="text-xs font-semibold uppercase tracking-[0.28em] text-stone-500 dark:text-stone-400 sm:text-sm">
                Reflexión más reciente
              </p>
              <h2 class="mt-4 text-balance text-3xl font-semibold tracking-[-0.03em] text-stone-950 dark:text-stone-50 sm:text-4xl">
                Regálate unos minutos para pensar.
              </h2>
            </div>
            <ReflectionFeature reflection={latest} brand={siteConfig.brand} headingLevel="h2" />
            <CommentsSection reflectionId={latest.id} reflectionSlug={latest.slug} returnTo="/" />
          </section>
        ) : (
          <section class="mx-auto mb-24 max-w-3xl rounded-3xl border border-stone-200 p-10 text-center dark:border-stone-800">
            <h2 class="text-2xl font-semibold">La primera reflexión está en camino</h2>
            <p class="mt-3 text-stone-600 dark:text-stone-300">
              Vuelve pronto. Las mejores ideas merecen escribirse sin prisa.
            </p>
          </section>
        )
      }
    </div>

    <section
      class="border-y border-stone-200/80 bg-stone-50/60 px-5 py-18 dark:border-white/[0.07] dark:bg-white/[0.018] sm:px-6 sm:py-20 lg:py-24"
    >
      <div class="mx-auto max-w-7xl">
        <div id="ultimas-reflexiones" class="landing-anchor landing-section-reveal max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-stone-500 dark:text-stone-400 sm:text-sm">
            Para seguir pensando
          </p>
          <h2
            class="mt-4 text-balance text-4xl font-semibold tracking-[-0.035em] text-stone-950 dark:text-stone-50 sm:text-5xl"
          >
            Últimas reflexiones
          </h2>
          <p class="mt-5 text-lg leading-8 text-stone-600 dark:text-stone-300">
            Tres ideas recientes para volver a ellas cuando necesites una perspectiva diferente.
          </p>
        </div>
        {
          previous.length > 0 ? (
            <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {previous.map((reflection) => (
                <div class="landing-section-reveal">
                  <ReflectionCard
                    reflection={reflection}
                    entrySource="home_previous"
                    likeCount={engagementAvailable ? (likeCounts.get(reflection.id) ?? 0) : undefined}
                    commentCount={engagementAvailable ? (commentCounts.get(reflection.id) ?? 0) : undefined}
                  />
                </div>
              ))}
            </div>
          ) : (
            <div class="mt-10 flex flex-col items-center justify-between gap-4 rounded-2xl border border-stone-200/80 bg-white/55 px-6 py-6 text-center dark:border-white/[0.07] dark:bg-white/[0.018] sm:flex-row sm:px-7 sm:text-left">
              <div>
                <p class="font-semibold text-stone-800 dark:text-stone-100">Nuevas reflexiones están en camino.</p>
                <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
                  Las mejores ideas merecen escribirse sin prisa.
                </p>
              </div>
              <span aria-hidden="true" class="text-xl text-amber-700/70 dark:text-amber-400/60">
                ✦
              </span>
            </div>
          )
        }
        <div class="mt-10 text-center">
          <a
            href="/reflexiones"
            data-analytics-cta="ver_todas_reflexiones"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-stone-300 bg-white px-7 py-3 font-semibold text-stone-900 transition duration-300 hover:-translate-y-0.5 hover:border-stone-500 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-stone-950 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-100 dark:hover:border-stone-500"
          >
            Ver todas las reflexiones<span aria-hidden="true" class="ml-2">→</span>
          </a>
        </div>
      </div>
    </section>

    <AboutSection about={siteConfig.about} />
    <SocialSection social={siteConfig.social} />
  </div>
</Layout>
