---
import ReflectionCard from '~/components/reflections/ReflectionCard.astro';
import { siteConfig } from '~/config/site';
import { getPublishedReflections } from '~/features/reflections/service';
import type { Reflection } from '~/features/reflections/types';
import Layout from '~/layouts/PageLayout.astro';

let reflections: Reflection[] = [];
let loadError = false;

try {
  reflections = await getPublishedReflections(24);
} catch (error) {
  console.error('No se pudo cargar la biblioteca de reflexiones', error);
  loadError = true;
}

const metadata = {
  title: 'Reflexiones',
  description: `Todas las reflexiones de ${siteConfig.brand.name} para pensar con claridad y vivir con propósito.`,
  canonical: `${siteConfig.brand.siteUrl}/reflexiones`,
};
---

<Layout metadata={metadata}>
  <section class="px-5 py-20 sm:px-6 sm:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-stone-500 dark:text-stone-400 sm:text-sm">
          Biblioteca
        </p>
        <h1
          class="mt-5 text-balance text-5xl font-semibold tracking-[-0.04em] text-stone-950 dark:text-stone-50 sm:text-6xl"
        >
          Reflexiones para volver a mirar.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-stone-600 dark:text-stone-300">
          Un lugar para explorar con calma las ideas que pueden ayudarte a pensar mejor y vivir con mayor propósito.
        </p>
      </div>
      {
        loadError ? (
          <div class="mt-14 rounded-3xl border border-red-200 bg-red-50 p-8 text-red-800 dark:border-red-950 dark:bg-red-950/20 dark:text-red-200">
            No pudimos cargar las reflexiones. Inténtalo de nuevo más tarde.
          </div>
        ) : reflections.length ? (
          <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {reflections.map((reflection) => (
              <ReflectionCard reflection={reflection} />
            ))}
          </div>
        ) : (
          <div class="mt-14 rounded-3xl border border-stone-200 p-10 text-center dark:border-stone-800">
            La biblioteca está esperando su primera reflexión.
          </div>
        )
      }
    </div>
  </section>
</Layout>
