---
import SiteFooter from '~/components/navigation/SiteFooter.astro';
import SiteHeader from '~/components/navigation/SiteHeader.astro';
import { siteConfig } from '~/config/site';
import Layout from '~/layouts/Layout.astro';
import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
  footerVariant?: 'default' | 'compact';
}

const { metadata, footerVariant = 'default' } = Astro.props;
---

<Layout metadata={metadata}>
  <slot name="header">
    <SiteHeader brand={siteConfig.brand} navigation={siteConfig.navigation} currentPath={Astro.url.pathname} />
  </slot>
  <main><slot /></main>
  <slot name="footer">
    <SiteFooter
      brand={siteConfig.brand}
      footer={siteConfig.footer}
      navigation={siteConfig.navigation}
      social={siteConfig.social}
      currentPath={Astro.url.pathname}
      variant={footerVariant}
    />
  </slot>
</Layout>
